# Coordinator runtime
SYSTEM_PORT=9090
SYSTEM_ADNL_PORT=16167
# Include token from secrets/metrics.token so Prometheus can scrape /metrics.
# You can add extra API tokens separated by comma.
SYSTEM_ACCESS_TOKENS=metrics-token,replace-with-api-token
SYSTEM_LOG_LEVEL=1
SYSTEM_STORE_HISTORY_DAYS=90

MASTER_ADDRESS=UQB3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d3d0x0
TON_CONFIG_URL=https://ton-blockchain.github.io/global.config.json
BATCH_SIZE=100

# Postgres (compose service "postgres")
DB_HOST=postgres
DB_PORT=5432
DB_USER=pguser
DB_PASSWORD=pgpassword
DB_NAME=providerdb
POSTGRES_PORT=5432

# Agent RPC fan-out
AGENT_ENDPOINTS=203.0.113.10:8443,203.0.113.11:8443,203.0.113.12:8443
AGENT_AUTH_TOKEN=replace-with-strong-shared-token
AGENT_CA_CERT_FILE=/run/secrets/agents-ca.crt
AGENT_RPC_TIMEOUT_MS=30000
COORDINATOR_RUNCHECKS_PING_MS=7000
COORDINATOR_RUNCHECKS_RLDP_MS=2000
COORDINATOR_RUNCHECKS_TOTAL_MS=1200000
COORDINATOR_STORAGERATES_QUERY_TIMEOUT_MS=14000

# Published host ports
COORDINATOR_PORT=8080
PROMETHEUS_PORT=9092
GRAFANA_PORT=3001

# Grafana admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
