# Agent runtime
AGENT_LISTEN_ADDR=:8443
AGENT_ID=agent-eu-1
AGENT_LOCATION=eu
AGENT_AUTH_TOKEN=replace-with-strong-shared-token
AGENT_TLS_CERT_FILE=/run/secrets/server.crt
AGENT_TLS_KEY_FILE=/run/secrets/server.key
AGENT_MAX_CONCURRENT_PROVIDERS=40
AGENT_MAX_CONCURRENT_RATES=40
AGENT_TON_CONFIG_URL=https://ton-blockchain.github.io/global.config.json
AGENT_ADNL_PORT=16167
# Optional fixed ADNL key seed (64 hex chars). Empty means generated at startup.
AGENT_ADNL_KEY=
AGENT_METRICS_LISTEN_ADDR=:9090
AGENT_LOKI_URL=http://loki:3100

# Published host ports
AGENT_GRPC_PORT=8443
PROMETHEUS_PORT=9091
GRAFANA_PORT=3000
LOKI_PORT=3100

# Grafana admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
